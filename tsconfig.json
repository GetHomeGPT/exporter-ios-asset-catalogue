{
  "compilerOptions": {
    "baseUrl": "./",
    "target": "es2021",
    "outDir": "build",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strictNullChecks": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "typeRoots": [
      "src/*",
      "types/*"
    ],
    "lib": ["ES2021", "DOM"]
  },
  "exclude": ["node_modules", "dist", "tests"]
}
