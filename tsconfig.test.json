{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "tests/.build",
    "rootDir": "."
  },
  "include": ["src/**/*", "tests/*.ts", "config.ts", "config.json"]
}
